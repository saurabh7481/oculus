{
  "name": "oculus",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime multiuser collaboration and syncing SDK.",
  "type": "module",
  "packageManager": "bun@1.2.23",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --workspaces --filter '*' dev",
    "build": "bun run --filter @oculus/sdk build && bun run --filter @oculus/svelte build && bun run --filter @oculus/server build && bun run --filter @oculus/demo build",
    "test": "vitest run",
    "typecheck": "tsc -b packages/server packages/sdk packages/svelte apps/demo",
    "server": "bun run --filter @oculus/server dev",
    "demo": "bun run --filter @oculus/demo dev"
  },
  "devDependencies": {
    "@types/bun": "^1.2.23",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
