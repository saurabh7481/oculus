{
  "name": "oculus",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime multiuser collaboration and syncing SDK.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build -w @oculus/sdk && npm run build -w @oculus/react && npm run build -w @oculus/server && npm run build -w @oculus/demo",
    "test": "vitest run",
    "typecheck": "tsc -b packages/server packages/sdk packages/react apps/demo",
    "server": "npm run dev -w @oculus/server",
    "demo": "npm run dev -w @oculus/demo"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
